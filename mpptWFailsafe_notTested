def close_server():
    global server

    try:
        if server:
            server.close()
    except:
        pass

    server = None


def start_web_server():
    global server, PICO_IP

    close_server()

    PICO_IP = wlan.ifconfig()[0]

    print("Connected!")
    print("Pico IP:", PICO_IP)
    print("Power URL: http://" + PICO_IP + "/pout")

    server = socket.socket()
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind(("0.0.0.0", 80))
    server.listen(1)
    server.setblocking(False)

    print("Web server running")
    print("Poll this from Flask: http://" + PICO_IP + "/pout")


def start_wifi_connect():
    global wifi_connecting, wifi_connect_start_ms

    print("Connecting...")
    wlan.connect(SSID, PASSWORD)
    wifi_connecting = True
    wifi_connect_start_ms = time.ticks_ms()


def update_wifi_connection():
    global wifi_connected, wifi_connecting
    global last_wifi_retry_ms, PICO_IP
    global last_sun, last_tick
    global sun_tick_valid, sun_tick_stable, sun_good_count

    now_ms = time.ticks_ms()

    # If already connected, keep checking that connection is still alive.
    if wifi_connected:
        if wlan.isconnected():
            return

        print("WiFi connection lost. Returning to MPPT failsafe mode.")

        wifi_connected = False
        wifi_connecting = False
        PICO_IP = "NO_WIFI"

        last_sun = None
        last_tick = None
        sun_tick_valid = False
        sun_tick_stable = False
        sun_good_count = 0

        close_server()
        last_wifi_retry_ms = now_ms
        return

    # If not connected and not already trying, retry every 5 seconds.
    if not wifi_connecting:
        if time.ticks_diff(now_ms, last_wifi_retry_ms) >= WIFI_RETRY_INTERVAL_MS:
            last_wifi_retry_ms = now_ms
            start_wifi_connect()

        return

    # If currently trying to connect, check whether connection succeeded.
    if wlan.isconnected():
        wifi_connected = True
        wifi_connecting = False

        last_sun = None
        last_tick = None
        sun_tick_valid = False
        sun_tick_stable = False
        sun_good_count = 0

        start_web_server()
        return

    # If connection attempt takes too long, give up and remain in failsafe mode.
    if time.ticks_diff(now_ms, wifi_connect_start_ms) >= WIFI_RECONNECT_TIMEOUT_MS:
        print("WiFi unavailable. Running MPPT failsafe mode.")
        wifi_connected = False
        wifi_connecting = False
        PICO_IP = "NO_WIFI"

        last_sun = None
        last_tick = None
        sun_tick_valid = False
        sun_tick_stable = False
        sun_good_count = 0

        close_server()
        last_wifi_retry_ms = now_ms


