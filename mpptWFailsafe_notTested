while True:
    # Keep WiFi state updated.
    # If disconnected, this will retry connection while MPPT failsafe keeps running.
    update_wifi_connection()

    # Webserver polling only runs when server exists.
    handle_web_request()

    if first_run:
        ina = ina219(SHUNT_OHMS, 64, 5)
        ina.configure()

        ina2 = ina219_2(SHUNT_OHMS, 0x44, 5)
        ina2.configure()

        first_run = 0

        loop_timer = Timer(mode=Timer.PERIODIC, freq=1000, callback=tick)

    if timer_elapsed == 1:
        va = 1.017 * (12490 / 2490) * 3.3 * (va_pin.read_u16() / 65536)
        vb = 1.015 * (12490 / 2490) * 3.3 * (vb_pin.read_u16() / 65536)

        vpot_in = 1.026 * 3.3 * (vpot_pin.read_u16() / 65536)
        v_pot_filt[v_pot_index] = vpot_in
        v_pot_index = v_pot_index + 1

        if v_pot_index == 100:
            v_pot_index = 0

        vpot = sum(v_pot_filt) / 100

        Vshunt = ina.vshunt()

        # Second current measurement
        Vshunt2 = ina2.vshunt()
        iL2_raw = Vshunt2 / SHUNT_OHMS

        il2_buf[il2_idx] = iL2_raw
        il2_idx = (il2_idx + 1) % IL2_FILT_LEN
        iL2 = sum(il2_buf) / IL2_FILT_LEN
        iL2_abs = abs(iL2)

        # In boost mode, Va is the output/load side.
        # Use abs(iL2), so shunt polarity does not make MPPT chase negative power.
        pout = va * iL2_abs

        sun_poll_counter = sun_poll_counter + 1
        mppt_failsafe_counter = mppt_failsafe_counter + 1

        if wifi_connected:
            # Try to read sun tick once per second.
            # Until ticks are stable, the MPPT failsafe remains active.
            if sun_poll_counter >= SUN_POLL_TICKS:
                sun_poll_counter = 0
                check_sun_change()

        if not wifi_connected or not sun_tick_stable:
            # Failsafe mode:
            # No WiFi OR unreadable/unstable ticks means force MPPT to rerun every 5 seconds.
            if mppt_failsafe_counter >= MPPT_FAILSAFE_TICKS:
                mppt_failsafe_counter = 0
                reset_mppt()
        else:
            # Normal mode:
            # WiFi is connected and sun ticks have been readable for several checks.
            # MPPT reset is now handled only by check_sun_change().
            mppt_failsafe_counter = 0

        CL = OL_CL_pin.value()
        BU = BU_BO_pin.value()

        if BU:
            # Buck mode
            min_pwm = 0
            max_pwm = 65500
            iL = Vshunt / SHUNT_OHMS
            iL_abs = abs(iL)

            pwm_ref = saturate(
                65536 - int(((vpot - 0.1) / 3) * 65536),
                max_pwm,
                min_pwm,
            )

            if CL != 1:
                # Buck open-loop
                reset_mppt()
                v_err_int = 0

                if iL > 3:
                    pwm_out = pwm_out - 100
                    OC = 1
                elif iL < 2.9:
                    pwm_out = pwm_out + 100
                    OC = 0

                pwm_out = saturate(pwm_out, pwm_ref, min_pwm)
                duty = int(65536 - pwm_out)
                pwm.duty_u16(duty)

            else:
                # Buck closed-loop
                reset_mppt()

                if iL > 3:
                    v_ref = v_ref - 0.1
                    OC = 1
                elif iL < 2.9:
                    v_ref = v_ref + 0.1
                    OC = 0

                v_ref = saturate(v_ref, vpot * 3, 0)
                v_err = v_ref - vb
                v_err_int = v_err_int + v_err
                v_err_int = saturate(v_err_int, 10000, -10000)
                v_pi_out = (kp * v_err) + (ki * v_err_int)

                pwm_out = saturate(v_pi_out, max_pwm, min_pwm)
                duty = int(65536 - pwm_out)
                pwm.duty_u16(duty)

        else:
            # Boost mode
            min_pwm = 0
            max_pwm = 60000
            iL = -(Vshunt / SHUNT_OHMS)
            iL_abs = abs(iL)

            pwm_ref = saturate(
                int(((vpot - 0.025) / 3) * 65536),
                max_pwm,
                min_pwm,
            )

            if CL != 1:
                # Boost open-loop
                reset_mppt()
                v_err_int = 0

                if iL > 1.6:
                    pwm_out = pwm_out - 100
                    OC = 1
                elif iL < 1.5:
                    pwm_out = pwm_out + 100
                    OC = 0

                pwm_out = saturate(pwm_out, pwm_ref, min_pwm)
                duty = int(pwm_out)
                pwm.duty_u16(duty)

            else:
                # Boost closed-loop with MPPT active
                if iL > 1.6:
                    OC = 1
                elif iL < 1.5:
                    OC = 0

                if OC:
                    # Current limit overrides MPPT by reducing duty
                    pwm_out = pwm_out - 100
                    pwm_out = saturate(pwm_out, max_pwm, min_pwm)
                    duty = int(pwm_out)

                else:
                    # MPPT directly controls boost duty
                    if mppt_done:
                        mppt_duty = mppt_hold_duty
                    else:
                        mppt_duty = mppt_ternary_step(pout)

                    pwm_out = saturate(mppt_duty, MPPT_MAX_DUTY, MPPT_MIN_DUTY)
                    duty = int(pwm_out)

                pwm.duty_u16(duty)

        count = count + 1
        timer_elapsed = 0

        if count > 100:
            print("Va = {:.3f}".format(va))
            print("Vb = {:.3f}".format(vb))
            print("Vpot = {:.3f}".format(vpot))
            print("iL = {:.3f}".format(iL))
            print("|iL| = {:.3f}".format(iL_abs))
            print("iL2 = {:.3f}".format(iL2))
            print("|iL2| = {:.3f}".format(iL2_abs))
            print("pout = {:.3f}".format(pout))
            print("OC = {:b}".format(OC))
            print("CL = {:b}".format(CL))
            print("BU = {:b}".format(BU))
            print("duty = {:d}".format(duty))

            if wifi_connected:
                print("Pout URL = http://" + PICO_IP + "/pout")
                print("Data URL = http://" + PICO_IP + "/data")
            else:
                print("WiFi = DISCONNECTED")
                print("MPPT failsafe = rerun every 5 seconds")

            print("Sun = {}".format(last_sun))
            print("Sun tick = {}".format(last_tick))
            print("Sun tick valid = {}".format(sun_tick_valid))
            print("Sun tick stable = {}".format(sun_tick_stable))

