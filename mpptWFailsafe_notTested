def saturate(signal, upper, lower):
    if signal > upper:
        signal = upper

    if signal < lower:
        signal = lower

    return signal


def tick(t):
    global timer_elapsed

    timer_elapsed = 1


def extract_json_value(body, key):
    key_text = '"' + key + '"'
    key_pos = body.find(key_text)

    if key_pos < 0:
        return None

    colon_pos = body.find(":", key_pos)

    if colon_pos < 0:
        return None

    value_start = colon_pos + 1

    while value_start < len(body) and body[value_start] == " ":
        value_start = value_start + 1

    value_end = value_start

    while value_end < len(body):
        char = body[value_end]

        if char == "," or char == "}":
            break

        value_end = value_end + 1

    raw_value = body[value_start:value_end].strip()

    if raw_value == "null" or raw_value == "None" or raw_value == "":
        return None

    try:
        if "." in raw_value:
            return float(raw_value)

        return int(raw_value)

    except:
        return None


def poll_sun_data():
    s = None

    try:
        addr = socket.getaddrinfo(SUN_SERVER_HOST, SUN_SERVER_PORT)[0][-1]

        s = socket.socket()
        s.settimeout(1)
        s.connect(addr)

        request = (
            "GET " + SUN_SERVER_PATH + " HTTP/1.1\r\n"
            "Host: " + SUN_SERVER_HOST + "\r\n"
            "Connection: close\r\n"
            "\r\n"
        )

        s.send(request.encode())

        response = b""

        while True:
            chunk = s.recv(128)

            if not chunk:
                break

            response = response + chunk

            if len(response) > 768:
                break

        s.close()

        text = response.decode()
        split_pos = text.find("\r\n\r\n")

        if split_pos >= 0:
            body = text[split_pos + 4:]
        else:
            body = text

        sun_value = extract_json_value(body, "sun")
        sun_tick = extract_json_value(body, "tick")

        return sun_value, sun_tick

    except:
        try:
            if s:
                s.close()
        except:
            pass

        return None, None


def check_sun_change():
    global last_sun, last_tick
    global sun_tick_valid, sun_tick_stable, sun_good_count

    sun_value, sun_tick = poll_sun_data()

    if sun_tick is None:
        sun_tick_valid = False
        sun_tick_stable = False
        sun_good_count = 0
        return

    sun_tick_valid = True
    sun_good_count = sun_good_count + 1

    if sun_good_count >= SUN_STABLE_READS:
        sun_tick_stable = True

    if last_tick is None:
        last_tick = sun_tick
        last_sun = sun_value
        return

    if sun_tick != last_tick:
        if sun_value != last_sun:
            reset_mppt()

        last_tick = sun_tick
        last_sun = sun_value


def handle_web_request():
    global pout, va, vb, vpot
    global duty, iL, iL_abs, iL2, iL2_abs
    global mppt_duty, mppt_lo, mppt_hi, mppt_state
    global mppt_p1, mppt_p2
    global server

    if server is None:
        return

    try:
        cl, addr = server.accept()
    except OSError:
        return

    try:
        cl.settimeout(1)
        request = cl.recv(1024).decode()

        if "GET /pout" in request:
            body = str(pout)

        elif "GET /data" in request:
            body = (
                '{{"pout": {}, "va": {}, "vb": {}, "vpot": {}, '
                '"duty": {}, "iL": {}, "iL_abs": {}, '
                '"iL2": {}, "iL2_abs": {}, '
                '"mppt_duty": {}, "mppt_lo": {}, "mppt_hi": {}, '
                '"mppt_state": {}, "mppt_p1": {}, "mppt_p2": {}}}'
            ).format(
                pout,
                va,
                vb,
                vpot,
                duty,
                iL,
                iL_abs,
                iL2,
                iL2_abs,
                mppt_duty,
                mppt_lo,
                mppt_hi,
                mppt_state,
                mppt_p1,
                mppt_p2,
            )

        else:
            body = "HELLO FROM PICO. Use /pout for power or /data for telemetry."

        response = (
            "HTTP/1.1 200 OK\r\n"
            "Content-Type: text/plain\r\n"
            "Connection: close\r\n"
            "Access-Control-Allow-Origin: *\r\n"
            "\r\n"
            + body
        )

        cl.sendall(response.encode())

    except Exception as e:
        print("Web error:", e)

    try:
        cl.close()
    except:
        pass


def reset_mppt():
    global mppt_lo, mppt_hi
    global mppt_m1, mppt_m2
    global mppt_p1, mppt_p2
    global mppt_count, mppt_state
    global mppt_duty
    global mppt_done, mppt_hold_duty

    mppt_lo = MPPT_MIN_DUTY
    mppt_hi = MPPT_MAX_DUTY
    mppt_m1 = 0
    mppt_m2 = 0
    mppt_p1 = 0.0
    mppt_p2 = 0.0
    mppt_count = 0
    mppt_state = 0
    mppt_duty = MPPT_MIN_DUTY
    mppt_done = False
    mppt_hold_duty = MPPT_MIN_DUTY


def mppt_ternary_step(pout):
    global mppt_lo, mppt_hi
    global mppt_m1, mppt_m2
    global mppt_p1, mppt_p2
    global mppt_count, mppt_state
    global mppt_duty
    global mppt_done, mppt_hold_duty

    # If bracket is small enough, use midpoint, then hold sweep
    if mppt_hi - mppt_lo < MPPT_TOL:
        mppt_duty = int((mppt_lo + mppt_hi) / 2)
        mppt_hold_duty = mppt_duty
        mppt_done = True

        return mppt_duty

    # State 0: choose ternary probe points
    if mppt_state == 0:
        third = int((mppt_hi - mppt_lo) / 3)
        mppt_m1 = mppt_lo + third
        mppt_m2 = mppt_hi - third

        mppt_p1 = 0.0
        mppt_p2 = 0.0
        mppt_count = 0

        mppt_duty = mppt_m1
        mppt_state = 1

        return mppt_duty

    # State 1: dwell at m1 and average power
    elif mppt_state == 1:
        mppt_p1 = mppt_p1 + pout
        mppt_count = mppt_count + 1

        if mppt_count >= MPPT_DWELL:
            mppt_p1 = mppt_p1 / MPPT_DWELL
            mppt_count = 0
            mppt_duty = mppt_m2
            mppt_state = 2

        return mppt_duty

    # State 2: dwell at m2 and average power
    elif mppt_state == 2:
        mppt_p2 = mppt_p2 + pout
        mppt_count = mppt_count + 1

        if mppt_count >= MPPT_DWELL:
            mppt_p2 = mppt_p2 / MPPT_DWELL

            # Maximise power
            if mppt_p1 < mppt_p2:
                mppt_lo = mppt_m1
            else:
                mppt_hi = mppt_m2

            mppt_duty = int((mppt_lo + mppt_hi) / 2)
            mppt_state = 0
            mppt_count = 0

        return mppt_duty

    return mppt_duty


# -----------------------------------------------------------------------------
# INA219 on I2C bus 0
# -----------------------------------------------------------------------------

class ina219:
    REG_CONFIG = 0x00
    REG_SHUNTVOLTAGE = 0x01
    REG_BUSVOLTAGE = 0x02
    REG_POWER = 0x03
    REG_CURRENT = 0x04
    REG_CALIBRATION = 0x05

    def __init__(self, sr, address, maxi):
        self.address = address
        self.shunt = sr

    def vshunt(icur):
        reg_bytes = ina_i2c.readfrom_mem(icur.address, icur.REG_SHUNTVOLTAGE, 2)
        reg_value = int.from_bytes(reg_bytes, "big")

        if reg_value > 2 ** 15:
            sign = -1
            for i in range(16):
                reg_value = reg_value ^ (1 << i)
        else:
            sign = 1

        return float(reg_value) * 1e-5 * sign

    def vbus(ivolt):
        reg_bytes = ina_i2c.readfrom_mem(ivolt.address, ivolt.REG_BUSVOLTAGE, 2)
        reg_value = int.from_bytes(reg_bytes, "big") >> 3

        return float(reg_value) * 0.004

    def configure(conf):
        ina_i2c.writeto_mem(conf.address, conf.REG_CONFIG, b"\x19\x9F")
        ina_i2c.writeto_mem(conf.address, conf.REG_CALIBRATION, b"\x00\x00")


