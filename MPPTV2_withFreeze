# Input-current change detection after MPPT lock
INPUT_CURRENT_CHANGE_A = 0.15          # absolute change threshold in amps
INPUT_CURRENT_CHANGE_FRAC = 0.20       # or 20 percent change
INPUT_CHANGE_COUNT_REQUIRED = 100      # must persist for 100 ms at 1 kHz

mppt_lo = MPPT_MIN_DUTY
